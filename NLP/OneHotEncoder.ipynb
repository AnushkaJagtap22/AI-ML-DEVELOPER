   "outputs": [],
   "source": [
    "from sklearn.preprocessing import OneHotEncoder"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "2a9e0c94-19e6-4eef-807b-94e7b73b553a",
   "metadata": {},
   "outputs": [],
   "source": [
    "data = [['Red'],['Blue'],['Green']]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "dbea1bd3-b880-4cee-bd98-a617ed43e5f7",
   "metadata": {},
   "outputs": [],
   "source": [
    "encoder = OneHotEncoder(sparse_output = False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "47fde9e3-4775-4bfe-a9d8-ab46df916c33",
   "metadata": {},
   "outputs": [],
   "source": [
    "encoded = encoder.fit_transform(data)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "3fbd273f-5ae6-44d7-aeb1-55f21d2acd2d",
